NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- dynamic challenges -----
# Base domain for per-team challenge subdomains.
# localtest.me always resolves to 127.0.0.1, so no DNS work locally.
NEXT_PUBLIC_DYNAMIC_BASE_DOMAIN=localtest.me
# Traefik listens on this host port. Use 80 if free, otherwise something like 8080.
DYNAMIC_TRAEFIK_PORT=80
# Docker network Traefik + instances share.
DOCKER_NETWORK=ctf-net
# Default instance TTL (seconds). 2h.
DYNAMIC_TTL_SECONDS=7200
# Shared secret for /api/cron/cleanup (infra/cron.sh sends this).
CRON_SECRET=change-me-to-a-long-random-string
# Optional: custom Docker socket path (defaults to /var/run/docker.sock).
# DOCKER_SOCKET=/var/run/docker.sock

# Optional: point at a remote Docker daemon instead of the local socket.
# When set, dockerode uses this URL and DOCKER_SOCKET is ignored.
# Examples:
#   ssh://ctf@challenges.yourname.com         (SSH transport — recommended)
#   tcp://challenges.yourname.com:2376        (TLS — set TLS env vars too)
# DOCKER_HOST=ssh://ctf@challenges.yourname.com
